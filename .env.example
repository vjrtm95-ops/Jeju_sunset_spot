SECRET_KEY=여기에-랜덤한-비밀키를-넣어주세요
DEBUG=True

# 카카오맵 (https://developers.kakao.com)
KAKAO_MAP_KEY=카카오맵-JavaScript키를-여기에

# 날씨 API (https://openweathermap.org — 없으면 날씨 기능 비활성)
OPENWEATHER_API_KEY=오픈웨더맵-API키를-여기에

# Cloudinary 미디어 스토리지 (https://cloudinary.com — Render 배포 시 필수)
# 로컬 개발 시에는 USE_CLOUDINARY=False 로 두면 로컬에 저장됩니다
USE_CLOUDINARY=False
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Render 배포 시 자동으로 DATABASE_URL이 설정됩니다 (직접 입력 불필요)
# DATABASE_URL=postgresql://...
